---
import Layout from '../../layouts/Layout.astro';
import { loadFeedItems } from '../../utils/feed';
import { categoryLabel, categorySlugFromBadge, getFirstSentence, getSmartBadge, truncateText } from '../../utils/helpers';

export async function getStaticPaths() {
  const feedItems = loadFeedItems().filter((item: any) => item.has_en && item.text_en && item.post_id);
  const categories = new Set(feedItems.map((item: any) => categorySlugFromBadge(getSmartBadge(item.text || item.text_en || ''))));
  return Array.from(categories).map((category) => ({ params: { category } }));
}

const { category } = Astro.params;
const label = categoryLabel(category || 'news', 'en');
const posts = loadFeedItems()
  .filter((item: any) => item.has_en && item.text_en && item.post_id)
  .filter((item: any) => categorySlugFromBadge(getSmartBadge(item.text || item.text_en || '')) === category)
  .sort((a: any, b: any) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .map((item: any) => ({
    url: `/${item.post_id}/${item.slug_en}/`,
    title: getFirstSentence(item.text_en || item.text || '') || `Post ${item.post_id}`,
    excerpt: truncateText(item.text_en || item.text || '', 170),
    date: item.date
  }));

const description = `${label} posts by Alex Getman about AI, automation, developer tools and self-hosted systems.`;
---

<Layout
  title={`${label} | Alex Getman`}
  description={description}
  canonicalUrl={`https://alexgetman.com/category/${category}/`}
  lang="en"
  siteName="Alex Getman"
  alternateLinks={[
    { hreflang: "en", href: `https://alexgetman.com/category/${category}/` },
    { hreflang: "ru", href: `https://alexgetman.com/ru/category/${category}/` },
    { hreflang: "x-default", href: `https://alexgetman.com/category/${category}/` }
  ]}
>
  <main class="category-page">
    <p class="eyebrow">Category</p>
    <h1>{label}</h1>
    <div class="post-list">
      {posts.map((post) => (
        <a href={post.url} class="post-row">
          <time datetime={post.date}>{new Date(post.date).toLocaleDateString('en-GB', { timeZone: 'Europe/Moscow' })}</time>
          <strong>{post.title}</strong>
          <span>{post.excerpt}</span>
        </a>
      ))}
    </div>
  </main>
</Layout>

<style>
  .category-page { max-width: 920px; margin: 0 auto; padding: 2rem 0 4rem; }
  .eyebrow { margin: 0 0 0.75rem; color: var(--accent); font-family: var(--font-mono); font-size: 0.82rem; font-weight: 800; }
  h1 { margin: 0 0 2rem; font-size: clamp(2.4rem, 5vw, 4.2rem); line-height: 1.02; letter-spacing: 0; }
  .post-list { display: grid; gap: 0.75rem; }
  .post-row { display: grid; grid-template-columns: 120px 1fr; gap: 0.2rem 1rem; padding: 1rem 0; border-bottom: 1px solid var(--border); color: var(--text-main); }
  .post-row time { color: var(--text-muted); font-size: 0.9rem; }
  .post-row strong { color: var(--text-header); }
  .post-row span { grid-column: 2; color: var(--text-secondary); font-size: 0.95rem; }
  @media (max-width: 640px) {
    .post-row { grid-template-columns: 1fr; }
    .post-row span { grid-column: auto; }
  }
</style>
