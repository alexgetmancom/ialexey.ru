---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page not found | Alex Getman"
  description="The requested page was not found on alexgetman.com."
  canonicalUrl="https://alexgetman.com/404/"
  lang="en"
  siteName="Alex Getman"
  robots="noindex, follow"
>
  <main class="not-found">
    <p class="eyebrow">404</p>
    <h1>Page not found</h1>
    <p>The page may have moved or the address may be incorrect.</p>
    <div class="actions">
      <a href="/">English home</a>
      <a href="/ru/">Russian home</a>
    </div>
  </main>
</Layout>

<style>
  .not-found {
    max-width: 760px;
    margin: 0 auto;
    padding: 5rem 0 7rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 800;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.8rem, 6vw, 5rem);
    line-height: 1;
    letter-spacing: 0;
  }

  p {
    color: var(--text-secondary);
    font-size: 1.1rem;
  }

  .actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .actions a {
    display: inline-flex;
    align-items: center;
    min-height: 40px;
    padding: 0.55rem 0.85rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--text-main);
  }
</style>
