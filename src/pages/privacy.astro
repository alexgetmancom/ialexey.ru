---
import Layout from '../layouts/Layout.astro';

const title = "Privacy Policy | Alex Getman";
const description = "Privacy policy for alexgetman.com: what technical data is processed, how pageview analytics works and how to contact the site owner.";
---

<Layout
  title={title}
  description={description}
  canonicalUrl="https://alexgetman.com/privacy/"
  lang="en"
  siteName="Alex Getman"
  alternateLinks={[
    { hreflang: "en", href: "https://alexgetman.com/privacy/" },
    { hreflang: "ru", href: "https://alexgetman.com/ru/privacy/" },
    { hreflang: "x-default", href: "https://alexgetman.com/privacy/" }
  ]}
>
  <main class="content-page">
    <p class="eyebrow">Privacy</p>
    <h1>Privacy Policy</h1>
    <p class="lead">alexgetman.com is a personal publication site. It keeps data collection minimal and uses technical logs, simple pageview analytics and local preferences to operate the site.</p>

    <section>
      <h2>Data processed</h2>
      <p>The site may process standard server log data, page paths, timestamps, referrers and basic browser metadata. Pageview and like endpoints may store aggregate counters and hashed technical identifiers for abuse prevention.</p>
    </section>

    <section>
      <h2>Cookies and local storage</h2>
      <p>The site can store display preferences such as theme and language in your browser. These values are used only to render the site consistently.</p>
    </section>

    <section>
      <h2>Comments and external services</h2>
      <p>Comments are powered by Giscus through GitHub Discussions. If you use comments or external social links, those services process data under their own privacy policies.</p>
    </section>

    <section>
      <h2>Contact</h2>
      <p>For privacy questions, contact <a href="mailto:i@alexgetman.com">i@alexgetman.com</a>.</p>
    </section>
  </main>
</Layout>

<style>
  .content-page { max-width: 780px; margin: 0 auto; padding: 2rem 0 4rem; }
  .eyebrow { margin: 0 0 0.75rem; color: var(--accent); font-family: var(--font-mono); font-size: 0.82rem; font-weight: 800; }
  h1 { margin: 0; font-size: clamp(2.4rem, 5vw, 4.4rem); line-height: 1.02; letter-spacing: 0; }
  .lead { margin: 1rem 0 2rem; color: var(--text-secondary); font-size: 1.15rem; }
  section { margin-top: 2rem; }
  h2 { margin: 0 0 0.6rem; font-size: 1.35rem; letter-spacing: 0; }
  p { color: var(--text-secondary); }
</style>
