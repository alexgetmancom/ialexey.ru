---
import Layout from '../layouts/Layout.astro';
import projects from '../data/projects.json';

const title = "Проекты — Алексей Гетманец";
const description = "Публичные проекты alexgetmancom: open-source, self-hosted инфраструктура, AI automation, Telegram tooling и developer tools.";

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": title,
  "description": description,
  "url": "https://alexgetman.com/projects/",
  "mainEntity": projects.map((project) => ({
    "@type": "SoftwareSourceCode",
    "name": project.name,
    "description": project.description,
    "codeRepository": project.url,
    "programmingLanguage": "Various"
  }))
});
---

<Layout title={title} description={description} schema={schema}>
  <main class="projects-page">
    <section class="projects-hero" aria-labelledby="projects-title">
      <p class="projects-hero__eyebrow">alexgetmancom / projects</p>
      <h1 class="projects-hero__title" id="projects-title">Проекты, инструменты и публичные эксперименты</h1>
      <p class="projects-hero__text">
        Здесь собраны публичные направления: self-hosted инструменты, Telegram automation, agent/browser experiments, infrastructure и небольшие developer tools.
      </p>
    </section>

    <section class="projects-list" aria-label="Список проектов">
      {projects.map((project) => (
        <a href={project.url} class="project-row" target="_blank" rel="noopener noreferrer">
          <div class="project-row__body">
            <div class="project-row__meta">
              <span>{project.kind}</span>
              <span>{project.status}</span>
            </div>
            <h2 class="project-row__title">{project.name}</h2>
            <p class="project-row__description">{project.description}</p>
          </div>
          <span class="project-row__accent">{project.accent}</span>
        </a>
      ))}
    </section>
  </main>
</Layout>

<style>
  .projects-page {
    max-width: 920px;
    margin: 0 auto;
    padding: 1rem 0 3rem;
    min-width: 0;
  }

  .projects-hero {
    margin-bottom: 2rem;
    min-width: 0;
  }

  .projects-hero__eyebrow {
    margin: 0 0 0.5rem;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.78rem;
    font-weight: 800;
  }

  .projects-hero__title {
    margin: 0;
    color: var(--text-header);
    font-size: clamp(2rem, 5vw, 4rem);
    line-height: 1.04;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .projects-hero__text {
    margin: 1rem 0 0;
    color: var(--text-secondary);
    max-width: 720px;
    font-size: 1.02rem;
    line-height: 1.6;
    overflow-wrap: anywhere;
  }

  .projects-list {
    display: grid;
    gap: 0.85rem;
    min-width: 0;
  }

  .project-row {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1rem;
    align-items: center;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    color: var(--text-main);
    min-width: 0;
  }

  .project-row:hover {
    color: var(--text-main);
    border-color: var(--border-hover);
    box-shadow: 0 8px 24px var(--accent-glow);
    transform: translateY(-2px);
  }

  .project-row__body {
    min-width: 0;
  }

  .project-row__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.55rem;
    margin-bottom: 0.45rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.7rem;
    line-height: 1.25;
  }

  .project-row__title {
    margin: 0;
    color: var(--text-header);
    font-size: 1.15rem;
    line-height: 1.25;
    overflow-wrap: anywhere;
  }

  .project-row__description {
    margin: 0.55rem 0 0;
    color: var(--text-secondary);
    font-size: 0.94rem;
    line-height: 1.55;
    overflow-wrap: anywhere;
  }

  .project-row__accent {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.74rem;
    line-height: 1.25;
    white-space: nowrap;
  }

  @media (max-width: 680px) {
    .project-row {
      grid-template-columns: 1fr;
    }

    .project-row__accent {
      white-space: normal;
    }
  }
</style>
