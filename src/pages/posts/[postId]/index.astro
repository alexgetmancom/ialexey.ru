---
import Layout from '../../../layouts/Layout.astro';
import { loadFeedItems } from '../../../utils/feed';

export async function getStaticPaths() {
  return loadFeedItems()
    .filter((item: any) => item.post_id)
    .map((item: any) => ({ params: { postId: String(item.post_id) }, props: { item } }));
}

const { item } = Astro.props;
const target = item?.has_en && item?.slug_en
  ? `/${item.post_id}/${item.slug_en}/`
  : `/ru/${item.post_id}/${item.slug_ru}/`;
---

<Layout title="Old post URL | Alex Getman" description="This legacy post URL has moved." canonicalUrl={`https://alexgetman.com${target}`} robots="noindex, follow">
  <main class="legacy-page">
    <h1>Post URL moved</h1>
    <p>This old address is intentionally excluded from the index.</p>
    <a href={target}>Open canonical post</a>
  </main>
</Layout>

<style>
  .legacy-page { max-width: 720px; margin: 0 auto; padding: 4rem 0; }
</style>
