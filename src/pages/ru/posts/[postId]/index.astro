---
import Layout from '../../../../layouts/Layout.astro';
import { loadFeedItems } from '../../../../utils/feed';

export async function getStaticPaths() {
  return loadFeedItems()
    .filter((item: any) => item.has_ru && item.post_id && item.slug_ru)
    .map((item: any) => ({ params: { postId: String(item.post_id) }, props: { item } }));
}

const { item } = Astro.props;
const target = `/ru/${item.post_id}/${item.slug_ru}/`;
---

<Layout title="Старый адрес поста | Алексей Гетманец" description="Этот старый адрес поста переехал." canonicalUrl={`https://alexgetman.com${target}`} lang="ru" siteName="Алексей Гетманец" rssHref="/ru/feed.xml" robots="noindex, follow">
  <main class="legacy-page">
    <h1>Адрес поста изменился</h1>
    <p>Эта старая страница намеренно закрыта от индексации.</p>
    <a href={target}>Открыть canonical-пост</a>
  </main>
</Layout>

<style>
  .legacy-page { max-width: 720px; margin: 0 auto; padding: 4rem 0; }
</style>
