---
import Layout from '../../layouts/Layout.astro';

const description = "Поиск по русским публикациям alexgetman.com по заголовку, тексту и категории.";
---

<Layout
  title="Поиск | Алексей Гетманец"
  description={description}
  canonicalUrl="https://alexgetman.com/ru/search/"
  lang="ru"
  siteName="Алексей Гетманец"
  rssHref="/ru/feed.xml"
  alternateLinks={[
    { hreflang: "en", href: "https://alexgetman.com/search/" },
    { hreflang: "ru", href: "https://alexgetman.com/ru/search/" },
    { hreflang: "x-default", href: "https://alexgetman.com/search/" }
  ]}
>
  <main class="search-page">
    <p class="eyebrow">Поиск</p>
    <h1>Поиск по постам</h1>
    <form class="search-form" role="search">
      <input id="page-search-input" name="q" type="search" placeholder="Тема, платформа или инструмент" autocomplete="off" />
      <button type="submit">Искать</button>
    </form>
    <div id="page-search-results" class="results" aria-live="polite"></div>
  </main>
</Layout>

<style>
  .search-page { max-width: 920px; margin: 0 auto; padding: 2rem 0 4rem; }
  .eyebrow { margin: 0 0 0.75rem; color: var(--accent); font-family: var(--font-mono); font-size: 0.82rem; font-weight: 800; }
  h1 { margin: 0 0 1.5rem; font-size: clamp(2.4rem, 5vw, 4.2rem); line-height: 1.02; letter-spacing: 0; }
  .search-form { display: flex; gap: 0.75rem; margin-bottom: 1.5rem; }
  .search-form input { flex: 1; min-width: 0; padding: 0.85rem 1rem; border: 1px solid var(--border); border-radius: 8px; background: var(--card-bg); color: var(--text-main); font: inherit; }
  .search-form button { padding: 0.85rem 1rem; border: 1px solid var(--border); border-radius: 8px; background: var(--accent); color: white; font-weight: 800; cursor: pointer; }
  .results { display: grid; gap: 0.75rem; }
  .result-row { display: grid; gap: 0.25rem; padding: 1rem 0; border-bottom: 1px solid var(--border); color: var(--text-main); }
  .result-row strong { color: var(--text-header); }
  .result-row span { color: var(--text-secondary); }
  .result-row small { color: var(--text-muted); font-family: var(--font-mono); }
  .empty { color: var(--text-secondary); }
  @media (max-width: 640px) { .search-form { flex-direction: column; } }
</style>

<script>
  const form = document.querySelector('.search-form');
  const input = document.getElementById('page-search-input') as HTMLInputElement | null;
  const results = document.getElementById('page-search-results');
  const params = new URLSearchParams(window.location.search);
  const initialQuery = params.get('q') || '';
  if (input) input.value = initialQuery;
  const normalize = (value: string) => value.toLowerCase().trim();
  const escapeHtml = (value: string) => value.replace(/[&<>"']/g, (ch) => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[ch] || ch));

  async function runSearch(query: string) {
    if (!results) return;
    const q = normalize(query);
    const response = await fetch('/search-index.json');
    const data = await response.json();
    const items = (data.items || [])
      .filter((item: any) => item.url.startsWith('/ru/'))
      .filter((item: any) => !q || normalize(`${item.title} ${item.excerpt} ${item.category}`).includes(q))
      .slice(0, 80);
    results.innerHTML = items.length ? items.map((item: any) => `
      <a class="result-row" href="${escapeHtml(item.url)}">
        <small>${escapeHtml(item.category || 'Пост')}</small>
        <strong>${escapeHtml(item.title || 'Пост')}</strong>
        <span>${escapeHtml(item.excerpt || '')}</span>
      </a>
    `).join('') : '<p class="empty">Ничего не найдено.</p>';
  }

  form?.addEventListener('submit', (event) => {
    event.preventDefault();
    const query = input?.value || '';
    history.replaceState(null, '', query ? `/ru/search/?q=${encodeURIComponent(query)}` : '/ru/search/');
    runSearch(query);
  });

  runSearch(initialQuery);
</script>
