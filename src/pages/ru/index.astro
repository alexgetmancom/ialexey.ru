---
import Layout from '../../layouts/Layout.astro';
import HomeNewsPage from '../../components/HomeNewsPage.astro';
import projects from '../../data/projects.json';
import fs from 'node:fs';
import path from 'node:path';
import { loadFeedItems } from '../../utils/feed';
import {
  categoryLabel,
  categorySlugFromBadge,
  excerptAfterTitle,
  formatRelativeTime,
  getFirstSentence,
  getSmartBadge,
  postImagePath,
  postVisualMedia
} from '../../utils/helpers';

const feedItems = loadFeedItems();

function existingSiteImage(publicPath) {
  if (!publicPath) return null;
  const candidates = [
    path.resolve('public', publicPath),
    path.resolve(publicPath),
    path.join(process.env.SITE_ROOT || '/home/deploy/ialexey-web', publicPath),
  ];
  return candidates.some((candidate) => fs.existsSync(candidate)) ? publicPath : null;
}

function responsiveSrcSetFor(publicPath) {
  if (!publicPath || !/\.(png|jpe?g)$/i.test(publicPath)) return undefined;
  const publicFile = path.resolve('public', publicPath);
  if (!fs.existsSync(publicFile)) return undefined;
  const base = publicPath
    .replace(/^\/+/, '')
    .replace(/[\\/]/g, '-')
    .replace(/\.[a-z0-9]+$/i, '');
  return [360, 640, 960]
    .map((width) => `/generated/responsive/${base}-${width}.webp ${width}w`)
    .join(', ');
}

function toRussianPost(item) {
  const id = item.post_id;
  const text = item.text || "";
  const title = getFirstSentence(text) || `Пост ${id}`;
  const badge = getSmartBadge(text);
  const categorySlug = categorySlugFromBadge(badge);
  const visualMedia = postVisualMedia(item, 'ru');
  const visualPath = existingSiteImage(visualMedia?.path);
  return {
    id,
    url: `/ru/${id}/${item.slug_ru}/`,
    title,
    body: text,
    excerpt: excerptAfterTitle(text, title, 180),
    date: item.date,
    relativeDate: formatRelativeTime(item.date, 'ru'),
    image: visualPath,
    mediaType: visualPath ? visualMedia?.type || 'image' : null,
    imageSrcSet: visualMedia?.type === 'image' ? responsiveSrcSetFor(postImagePath(item, 'ru')) : undefined,
    views: Number(item.views || 0),
    categorySlug,
    category: categoryLabel(categorySlug, 'ru'),
  };
}

const russianPosts = feedItems
  .filter((item) => item.has_ru && item.text && item.post_id)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .map(toRussianPost);

const leadPost = russianPosts[0] || null;
const latestRussianPosts = russianPosts.slice(leadPost ? 1 : 0, leadPost ? 8 : 9);
const trendingPosts = [...russianPosts]
  .filter((post) => !leadPost || post.id !== leadPost.id)
  .sort((a, b) => (b.views - a.views) || (new Date(b.date).getTime() - new Date(a.date).getTime()))
  .slice(0, 5);
const topicStats = Array.from(
  russianPosts.reduce((map, post) => {
    const current = map.get(post.categorySlug) || { slug: post.categorySlug, label: post.category, count: 0 };
    current.count += 1;
    map.set(post.categorySlug, current);
    return map;
  }, new Map()).values()
).sort((a, b) => b.count - a.count);

const title = "Алексей Гетманец | новости ИИ и developer tools";
const description = "Новости ИИ, developer tools, автоматизация и изменения продуктов от Алексея Гетманца.";

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://alexgetman.com/#person",
      "name": "Алексей Гетманец",
      "alternateName": "Alex Getman",
      "url": "https://alexgetman.com/ru/",
      "image": "https://alexgetman.com/avatar.png",
      "sameAs": [
        "https://t.me/alexgetmancom",
        "https://www.threads.net/@alexgetmanru",
        "https://www.youtube.com/@alexgetmancom",
        "https://www.twitch.tv/alexgetmancom",
        "https://github.com/alexgetmancom",
        "https://www.linkedin.com/in/alexgetmancom",
        "https://www.instagram.com/alexgetmancom/",
        "https://www.facebook.com/profile.php?id=61590942205426",
        "https://discord.gg/Z7sSm56rcb"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://alexgetman.com/#website",
      "url": "https://alexgetman.com/ru/",
      "name": "Алексей Гетманец",
      "description": description,
      "inLanguage": "ru-RU",
      "publisher": { "@id": "https://alexgetman.com/#person" }
    },
    {
      "@type": "CollectionPage",
      "@id": "https://alexgetman.com/ru/#home",
      "url": "https://alexgetman.com/ru/",
      "name": title,
      "description": description,
      "inLanguage": "ru-RU",
      "isPartOf": { "@id": "https://alexgetman.com/#website" }
    }
  ]
});

const labels = {
  archive: "Архив",
  search: "Поиск",
  languageSwitch: "EN",
  empty: "Русские посты появятся здесь после публикации.",
  latestPosts: "Последние русские посты",
  latestUpdates: "Последние обновления",
  trending: "Популярное",
  topics: "Темы",
  projects: "Проекты",
  all: "Все",
  sidebarLabel: "Боковые разделы главной страницы",
  mskSuffix: "МСК"
};
---

<Layout
  title={title}
  description={description}
  schema={schema}
  canonicalUrl="https://alexgetman.com/ru/"
  lang="ru"
  siteName="Алексей Гетманец"
  rssHref="/ru/feed.xml"
  alternateLinks={[
    { hreflang: "en", href: "https://alexgetman.com/" },
    { hreflang: "ru", href: "https://alexgetman.com/ru/" },
    { hreflang: "x-default", href: "https://alexgetman.com/" }
  ]}
>
  <HomeNewsPage
    posts={russianPosts}
    latestPosts={latestRussianPosts}
    trendingPosts={trendingPosts}
    topicStats={topicStats}
    projects={projects}
    labels={labels}
    locale="ru"
    categoryBasePath="/ru/category/"
  />
</Layout>
