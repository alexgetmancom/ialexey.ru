---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../../layouts/Layout.astro';
import { getFirstSentence, truncateText } from '../../utils/helpers';

const dataDir = process.env.DATA_DIR || '/home/deploy/ialexey-feed/data';
const prodFeedJsonPath = path.join(dataDir, 'feed.json');
const localFeedJsonPath = path.resolve('src/data/feed.json');

let parsedData = null;
for (const filePath of [prodFeedJsonPath, localFeedJsonPath]) {
  if (!parsedData && fs.existsSync(filePath)) {
    try {
      parsedData = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
    } catch (e) {
      console.error(`Error reading ${filePath}:`, e);
    }
  }
}

let feedItems = [];
if (Array.isArray(parsedData)) {
  feedItems = parsedData;
} else if (parsedData?.items && Array.isArray(parsedData.items)) {
  feedItems = parsedData.items;
}

const posts = feedItems
  .filter((item) => item.has_ru && item.post_id)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .map((item) => ({
    id: item.post_id,
    url: `/ru/${item.post_id}/${item.slug_ru}/`,
    title: getFirstSentence(item.text || "") || `Пост ${item.post_id}`,
    excerpt: truncateText(item.text || "", 150),
    date: item.date
  }));

function formatMonth(value) {
  try {
    return new Intl.DateTimeFormat("ru-RU", {
      timeZone: "Europe/Moscow",
      month: "long",
      year: "numeric"
    }).format(new Date(value));
  } catch (e) {
    return "Архив";
  }
}

function formatDate(value) {
  try {
    return new Intl.DateTimeFormat("ru-RU", {
      timeZone: "Europe/Moscow",
      day: "2-digit",
      month: "short",
      year: "numeric"
    }).format(new Date(value));
  } catch (e) {
    return value || "";
  }
}

const groupedPosts = posts.reduce((groups, post) => {
  const key = formatMonth(post.date);
  if (!groups[key]) groups[key] = [];
  groups[key].push(post);
  return groups;
}, {});

const description = "Архив русских публикаций Алексея Гетманца про ИИ, автоматизацию, developer tools и self-hosted системы.";
---

<Layout
  title="Архив | Алексей Гетманец"
  description={description}
  canonicalUrl="https://alexgetman.com/ru/archive/"
  lang="ru"
  siteName="Алексей Гетманец"
  rssHref="/ru/feed.xml"
  alternateLinks={[
    { hreflang: "en", href: "https://alexgetman.com/archive/" },
    { hreflang: "ru", href: "https://alexgetman.com/ru/archive/" },
    { hreflang: "x-default", href: "https://alexgetman.com/archive/" }
  ]}
>
  <main class="archive-page">
    <p class="eyebrow">Archive</p>
    <h1>Все русские публикации</h1>
    {Object.keys(groupedPosts).length > 0 ? Object.entries(groupedPosts).map(([month, monthPosts]) => (
      <section class="month-group">
        <h2>{month}</h2>
        <div class="archive-list">
          {monthPosts.map((post) => (
            <a href={post.url} class="archive-row">
              <time datetime={post.date}>{formatDate(post.date)}</time>
              <strong>{post.title}</strong>
              <span>{post.excerpt}</span>
            </a>
          ))}
        </div>
      </section>
    )) : (
      <p class="empty">Русские посты появятся здесь после публикации.</p>
    )}
  </main>
</Layout>

<style>
  .archive-page { max-width: 920px; margin: 0 auto; padding: 2rem 0 4rem; }
  .eyebrow { margin: 0 0 0.75rem; color: var(--accent); font-family: var(--font-mono); font-size: 0.82rem; font-weight: 800; }
  h1 { margin: 0 0 2rem; font-size: clamp(2.4rem, 5vw, 4.4rem); line-height: 1.02; letter-spacing: 0; }
  .month-group { margin-top: 2.25rem; }
  h2 { margin: 0 0 1rem; font-size: 1.25rem; letter-spacing: 0; text-transform: capitalize; }
  .archive-list { display: grid; gap: 0.75rem; }
  .archive-row { display: grid; grid-template-columns: 120px 1fr; gap: 0.2rem 1rem; padding: 1rem 0; border-bottom: 1px solid var(--border); color: var(--text-main); }
  .archive-row time { color: var(--text-muted); font-size: 0.9rem; }
  .archive-row strong { color: var(--text-header); }
  .archive-row span { grid-column: 2; color: var(--text-secondary); font-size: 0.95rem; }
  .empty { color: var(--text-secondary); }
  @media (max-width: 640px) {
    .archive-row { grid-template-columns: 1fr; }
    .archive-row span { grid-column: auto; }
  }
</style>
