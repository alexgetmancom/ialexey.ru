---
import Layout from '../layouts/Layout.astro';
import HomeNewsPage from '../components/HomeNewsPage.astro';
import projects from '../data/projects.json';
import fs from 'node:fs';
import path from 'node:path';
import { loadFeedItems } from '../utils/feed';
import {
  categoryLabel,
  categorySlugFromBadge,
  excerptAfterTitle,
  formatRelativeTime,
  getFirstSentence,
  getSmartBadge,
  postImagePath,
  postVisualMedia
} from '../utils/helpers';

const feedItems = loadFeedItems();

function existingSiteImage(publicPath) {
  if (!publicPath) return null;
  const candidates = [
    path.resolve('public', publicPath),
    path.resolve(publicPath),
    path.join(process.env.SITE_ROOT || '/home/deploy/ialexey-web', publicPath),
  ];
  return candidates.some((candidate) => fs.existsSync(candidate)) ? publicPath : null;
}

function responsiveSrcSetFor(publicPath) {
  if (!publicPath || !/\.(png|jpe?g)$/i.test(publicPath)) return undefined;
  const publicFile = path.resolve('public', publicPath);
  if (!fs.existsSync(publicFile)) return undefined;
  const base = publicPath
    .replace(/^\/+/, '')
    .replace(/[\\/]/g, '-')
    .replace(/\.[a-z0-9]+$/i, '');
  return [360, 640, 960]
    .map((width) => `/generated/responsive/${base}-${width}.webp ${width}w`)
    .join(', ');
}

function toEnglishPost(item) {
  const id = item.post_id;
  const text = item.text_en || item.text || "";
  const title = getFirstSentence(text) || `Post ${id}`;
  const badge = getSmartBadge(item.text || text);
  const categorySlug = categorySlugFromBadge(badge);
  const visualMedia = postVisualMedia(item, 'en');
  const visualPath = existingSiteImage(visualMedia?.path);
  return {
    id,
    url: `/${id}/${item.slug_en}/`,
    title,
    body: text,
    excerpt: excerptAfterTitle(text, title, 180),
    date: item.date,
    relativeDate: formatRelativeTime(item.date, 'en'),
    image: visualPath,
    mediaType: visualPath ? visualMedia?.type || 'image' : null,
    imageSrcSet: visualMedia?.type === 'image' ? responsiveSrcSetFor(postImagePath(item, 'en')) : undefined,
    views: Number(item.views || 0),
    categorySlug,
    category: categoryLabel(categorySlug, 'en'),
  };
}

const englishPosts = feedItems
  .filter((item) => item.has_en && item.text_en && item.post_id)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .map(toEnglishPost);

const leadPost = englishPosts[0] || null;
const latestEnglishPosts = englishPosts.slice(leadPost ? 1 : 0, leadPost ? 8 : 9);
const trendingPosts = [...englishPosts]
  .filter((post) => !leadPost || post.id !== leadPost.id)
  .sort((a, b) => (b.views - a.views) || (new Date(b.date).getTime() - new Date(a.date).getTime()))
  .slice(0, 5);
const topicStats = Array.from(
  englishPosts.reduce((map, post) => {
    const current = map.get(post.categorySlug) || { slug: post.categorySlug, label: post.category, count: 0 };
    current.count += 1;
    map.set(post.categorySlug, current);
    return map;
  }, new Map()).values()
).sort((a, b) => b.count - a.count);

const title = "Alex Getman | AI news and developer tools";
const description = "Latest AI news, developer tools, automation updates and product changes from Alex Getman.";

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://alexgetman.com/#person",
      "name": "Alex Getman",
      "url": "https://alexgetman.com/",
      "image": "https://alexgetman.com/avatar.png",
      "sameAs": [
        "https://t.me/alexgetmancom",
        "https://www.threads.net/@alexgetmanco",
        "https://www.youtube.com/@alexgetmancom",
        "https://www.twitch.tv/alexgetmancom",
        "https://github.com/alexgetmancom",
        "https://www.linkedin.com/in/alexgetmancom",
        "https://www.instagram.com/alexgetmancom/",
        "https://www.facebook.com/profile.php?id=61590942205426",
        "https://discord.gg/Z7sSm56rcb"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://alexgetman.com/#website",
      "url": "https://alexgetman.com/",
      "name": "Alex Getman",
      "description": description,
      "inLanguage": "en-US",
      "publisher": { "@id": "https://alexgetman.com/#person" }
    },
    {
      "@type": "CollectionPage",
      "@id": "https://alexgetman.com/#home",
      "url": "https://alexgetman.com/",
      "name": title,
      "description": description,
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://alexgetman.com/#website" }
    }
  ]
});

const labels = {
  archive: "Archive",
  search: "Search",
  languageSwitch: "RU",
  empty: "English posts will appear here after publication approval.",
  latestPosts: "Latest English posts",
  latestUpdates: "Latest updates",
  trending: "Trending",
  topics: "Topics",
  projects: "Projects",
  all: "All",
  sidebarLabel: "Homepage side sections",
  mskSuffix: "MSK"
};
---

<Layout
  title={title}
  description={description}
  schema={schema}
  canonicalUrl="https://alexgetman.com/"
  lang="en"
  siteName="Alex Getman"
  rssHref="/feed.xml"
  alternateLinks={[
    { hreflang: "en", href: "https://alexgetman.com/" },
    { hreflang: "ru", href: "https://alexgetman.com/ru/" },
    { hreflang: "x-default", href: "https://alexgetman.com/" }
  ]}
>
  <HomeNewsPage
    posts={englishPosts}
    latestPosts={latestEnglishPosts}
    trendingPosts={trendingPosts}
    topicStats={topicStats}
    projects={projects}
    labels={labels}
    locale="en"
    categoryBasePath="/category/"
  />
</Layout>
