---
import fs from 'node:fs';
import path from 'node:path';
import Layout from '../layouts/Layout.astro';
import projects from '../data/projects.json';
import { getFirstSentence, truncateText } from '../utils/helpers';

const dataDir = process.env.DATA_DIR || '/home/deploy/ialexey-feed/data';
const prodFeedJsonPath = path.join(dataDir, 'feed.json');
const localFeedJsonPath = path.resolve('src/data/feed.json');

let parsedData = null;
for (const filePath of [prodFeedJsonPath, localFeedJsonPath]) {
  if (!parsedData && fs.existsSync(filePath)) {
    try {
      parsedData = JSON.parse(fs.readFileSync(filePath, 'utf-8'));
    } catch (e) {
      console.error(`Error reading ${filePath}:`, e);
    }
  }
}

let feedItems = [];
if (Array.isArray(parsedData)) {
  feedItems = parsedData;
} else if (parsedData?.items && Array.isArray(parsedData.items)) {
  feedItems = parsedData.items;
}

const latestEnglishPosts = feedItems
  .filter((item) => item.text_en)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime())
  .slice(0, 8)
  .map((item) => {
    const id = item.message_id || item.id?.split(':').pop();
    const text = item.text_en || item.text || "";
    return {
      id,
      url: `/en/posts/${id}/`,
      title: getFirstSentence(text) || `Telegram post ${id}`,
      excerpt: truncateText(text, 180),
      date: item.date
    };
  });

const title = "Alex Getman | AI, automation and self-hosted systems";
const description = "English hub for Alex Getman: AI news, automation, developer tools, self-hosted systems, public projects and translated Telegram posts.";

const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Person",
      "@id": "https://alexgetman.com/#person",
      "name": "Alex Getman",
      "alternateName": "Алексей Гетманец",
      "url": "https://alexgetman.com/",
      "image": "https://alexgetman.com/avatar.png",
      "sameAs": [
        "https://t.me/alexgetmancom",
        "https://www.threads.com/@alexgetmancom",
        "https://www.youtube.com/@alexgetmancom",
        "https://www.twitch.tv/alexgetmancom",
        "https://github.com/alexgetmancom",
        "https://www.linkedin.com/in/alexgetmancom",
        "https://www.instagram.com/alexgetmancom/",
        "https://www.facebook.com/profile.php?id=61590942205426",
        "https://discord.gg/Z7sSm56rcb"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://alexgetman.com/#website",
      "url": "https://alexgetman.com/",
      "name": "Alex Getman",
      "description": description,
      "inLanguage": "en-US",
      "publisher": { "@id": "https://alexgetman.com/#person" }
    },
    {
      "@type": "CollectionPage",
      "@id": "https://alexgetman.com/#home",
      "url": "https://alexgetman.com/",
      "name": title,
      "description": description,
      "inLanguage": "en-US",
      "isPartOf": { "@id": "https://alexgetman.com/#website" }
    }
  ]
});

function formatDate(value) {
  if (!value) return "";
  try {
    return new Intl.DateTimeFormat("en-GB", {
      timeZone: "Europe/Moscow",
      day: "2-digit",
      month: "short",
      year: "numeric",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    }).format(new Date(value));
  } catch (e) {
    return value;
  }
}
---

<Layout
  title={title}
  description={description}
  schema={schema}
  canonicalUrl="https://alexgetman.com/"
  lang="en"
  siteName="Alex Getman"
  rssHref="/feed.xml"
  alternateLinks={[
    { hreflang: "en", href: "https://alexgetman.com/" },
    { hreflang: "ru", href: "https://alexgetman.com/ru/" },
    { hreflang: "x-default", href: "https://alexgetman.com/" }
  ]}
>
  <main class="home-page">
    <section class="hero" aria-labelledby="home-title">
      <p class="hero__eyebrow">alexgetmancom</p>
      <h1 class="hero__title" id="home-title">AI, automation and self-hosted systems</h1>
      <p class="hero__text">
        I track practical AI product changes, build automation around publishing workflows, and document public projects across developer tools, infrastructure and media systems.
      </p>
      <div class="hero__actions">
        <a href="/ru/" class="home-link">Russian feed</a>
        <a href="/projects/" class="home-link">Projects</a>
        <a href="/contacts/" class="home-link">Contacts</a>
      </div>
    </section>

    <section class="section" aria-labelledby="posts-title">
      <div class="section__header">
        <h2 class="section__title" id="posts-title">Latest English posts</h2>
        <a href="/en/feed.json" class="section__link">JSON feed</a>
      </div>
      <div class="post-list">
        {latestEnglishPosts.length > 0 ? latestEnglishPosts.map((post) => (
          <a href={post.url} class="post-row">
            <span class="post-row__date">{formatDate(post.date)} MSK</span>
            <strong>{post.title}</strong>
            <span>{post.excerpt}</span>
          </a>
        )) : (
          <p class="empty">English posts will appear here after publication approval.</p>
        )}
      </div>
    </section>

    <section class="section" aria-labelledby="projects-title">
      <div class="section__header">
        <h2 class="section__title" id="projects-title">Public projects</h2>
        <a href="/projects/" class="section__link">All projects</a>
      </div>
      <div class="project-grid">
        {projects.slice(0, 4).map((project) => (
          <a href={project.url} class="project-card" target="_blank" rel="noopener noreferrer">
            <span>{project.kind}</span>
            <strong>{project.name}</strong>
            <small>{project.accent}</small>
          </a>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .home-page {
    max-width: 1040px;
    margin: 0 auto;
    padding: 1rem 0 3rem;
    min-width: 0;
  }

  .hero {
    padding: 2rem 0 2.5rem;
    min-width: 0;
  }

  .hero__eyebrow {
    margin: 0 0 0.6rem;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .hero__title {
    margin: 0;
    max-width: 900px;
    font-size: clamp(2.5rem, 5vw, 5rem);
    line-height: 1.02;
    letter-spacing: 0;
    overflow-wrap: anywhere;
  }

  .hero__text {
    max-width: 760px;
    margin: 1rem 0 0;
    color: var(--text-secondary);
    font-size: 1.05rem;
  }

  .hero__actions,
  .section__header {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .hero__actions {
    margin-top: 1.25rem;
  }

  .home-link,
  .section__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 38px;
    padding: 0.45rem 0.8rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    color: var(--text-main);
    font-weight: 700;
  }

  .home-link:hover,
  .section__link:hover {
    color: var(--text-header);
    border-color: var(--border-hover);
    background: var(--accent-glow);
  }

  .section {
    margin-top: 1.4rem;
  }

  .section__header {
    justify-content: space-between;
    margin-bottom: 0.85rem;
  }

  .section__title {
    margin: 0;
    font-size: 1.15rem;
  }

  .post-list,
  .project-grid {
    display: grid;
    gap: 0.75rem;
  }

  .post-row,
  .project-card {
    display: grid;
    gap: 0.25rem;
    padding: 1rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    min-width: 0;
  }

  .post-row span,
  .project-card span,
  .project-card small {
    color: var(--text-secondary);
  }

  .post-row__date {
    font-size: 0.82rem;
  }

  .project-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .empty {
    margin: 0;
    color: var(--text-secondary);
  }

  @media (max-width: 720px) {
    .hero {
      padding-top: 1rem;
    }

    .project-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
