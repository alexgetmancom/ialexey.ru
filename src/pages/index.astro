<script>
  // Homepage filtering: combines global search input with local category chips.
  document.addEventListener('DOMContentLoaded', () => {
      const filterableItems = Array.from(document.querySelectorAll('.sidebar-item, .featured-item-link, .article-card-uniform'));
      const gridContainer = document.querySelector('.page-layout-grid');
      const emptyState = document.getElementById('filter-empty-state');
      const categoryChips = Array.from(document.querySelectorAll('.category-chip'));
      const headerSearchInput = document.getElementById('header-search-input');

      let searchQuery = '';
      let filterKind = 'all';
      let filterValue = 'all';

      function matchesCategory(item) {
          if (filterKind === 'all') {
              return true;
          }
          if (filterKind === 'kind') {
              return item.getAttribute('data-kind') === filterValue;
          }
          if (filterKind === 'category') {
              return item.getAttribute('data-category') === filterValue;
          }
          return true;
      }

      function applyFilters() {
          const controlsActive = searchQuery !== '' || filterKind !== 'all';
          let visibleCount = 0;

          if (gridContainer) {
              if (controlsActive) {
                  gridContainer.classList.add('controls-active');
              } else {
                  gridContainer.classList.remove('controls-active');
              }
          }

          filterableItems.forEach(item => {
              const searchText = item.getAttribute('data-search-text') || '';
              const matchesSearch = searchText.includes(searchQuery);
              const categoryMatch = matchesCategory(item);

              if (matchesSearch) {
                  item.classList.remove('hidden-by-search');
              } else {
                  item.classList.add('hidden-by-search');
              }

              if (categoryMatch) {
                  item.classList.remove('hidden-by-category');
              } else {
                  item.classList.add('hidden-by-category');
              }

              if (matchesSearch && categoryMatch) {
                  visibleCount += 1;
              }
          });

          if (emptyState) {
              emptyState.classList.toggle('is-visible', controlsActive && visibleCount === 0);
          }
      }

      function syncSearch(value) {
          if (headerSearchInput && headerSearchInput.value !== value) {
              headerSearchInput.value = value;
          }
          searchQuery = value.toLowerCase().trim();
          applyFilters();
      }

      if (headerSearchInput) {
          headerSearchInput.addEventListener('input', (e) => {
              syncSearch(e.target.value);
          });
      }

      window.addEventListener('site-search-query', (e) => {
          syncSearch(e.detail?.query || '');
      });

      categoryChips.forEach((chip) => {
          chip.addEventListener('click', () => {
              filterKind = chip.getAttribute('data-filter-kind') || 'all';
              filterValue = chip.getAttribute('data-filter-value') || 'all';
              categoryChips.forEach((item) => item.classList.toggle('is-active', item === chip));
              applyFilters();
          });
      });

      const params = new URLSearchParams(window.location.search);
      const searchParam = params.get('search');
      if (searchParam) {
          syncSearch(searchParam);
      }
  });

  // Sidebar News Expander
  const sidebarShowMoreBtn = document.getElementById('sidebar-show-more-btn');
  const sidebarList = document.querySelector('.sidebar-list');
  if (sidebarShowMoreBtn && sidebarList) {
      sidebarShowMoreBtn.addEventListener('click', () => {
          sidebarList.classList.add('sidebar-list--expanded');
          const parent = sidebarShowMoreBtn.closest('.sidebar-show-more-wrap');
          if (parent) {
              (parent as HTMLElement).style.display = 'none';
          }
      });
  }
</script>
