  }

  .article-row--hidden {
      display: none !important;
  }

  .articles-list--expanded .article-row--hidden {
      display: flex !important;
      animation: fadeIn 0.4s ease forwards;
  }

  @keyframes fadeIn {
      from { opacity: 0; transform: translateY(10px); }
      to { opacity: 1; transform: translateY(0); }
  }

  .articles-show-more-wrap {
      display: flex;
      justify-content: center;
      margin-top: 2rem;
  }

  .show-more-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background-color: transparent;
      border: 1px solid var(--border);
      color: var(--text-header);
      padding: 0.75rem 2rem;
      border-radius: 8px;
      font-family: var(--font-heading);
      font-size: 0.85rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      cursor: pointer;
      transition: all 0.25s ease;
  }

  .show-more-btn:hover {
      background-color: var(--accent-glow);
      border-color: var(--accent);
      color: var(--accent);
      box-shadow: 0 4px 15px var(--accent-glow);
  }

  .show-more-btn__icon {
      width: 16px;
      height: 16px;
      transition: transform 0.25s ease;
  }

  .show-more-btn:hover .show-more-btn__icon {
      transform: translateY(2px);
  }

  /* RESPONSIVE SYSTEM */
  @media (max-width: 900px) {
      .page-layout-grid {
          grid-template-columns: 1fr;
          gap: 1.5rem;
      }
  }

  /* FAQ SECTION (AEO/SEO optimized) */
  .faq-section {
      margin-top: 2.5rem;
      border-top: none;
      padding-top: 0;
  }

  .faq-list {
      display: grid;
      gap: 1.75rem;
      margin-top: 1.5rem;
  }

  .faq-item {
      background-color: transparent;
      border: none;
      border-left: 3px solid var(--border);
      padding: 0 0 0 1.25rem;
      border-radius: 0;
      transition: border-color 0.25s ease;
      overflow: hidden;
  }

  .faq-item:hover {
      border-left-color: var(--accent);
      box-shadow: none;
  }

  /* FAQ main collapse styles */
  .faq-header-row {
      display: inline-flex;
      align-items: center;
      gap: 1.25rem;
      margin-bottom: 1.5rem;
      transition: margin 0.3s ease;
      cursor: pointer;
      user-select: none;
  }

  .faq-section--collapsed .faq-header-row {
      margin-bottom: 0;
  }

  .toggle-faq-btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--card-bg);
      border: 1px solid var(--border);
      color: var(--text-header);
      font-family: var(--font-heading);
      font-size: 0.88rem;
      font-weight: 600;
      cursor: pointer;
      padding: 6px 14px;
      border-radius: 8px;
      transition: all 0.2s ease;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .toggle-faq-btn:hover {
      border-color: var(--accent);
      color: var(--accent);
      background-color: var(--accent-glow);
  }

  .faq-toggle-icon {
      width: 14px;
      height: 14px;
      transition: transform 0.3s ease;
  }

  /* Rotate icon when collapsed (arrow pointing down) */
  .faq-section--collapsed .faq-toggle-icon {
      transform: rotate(180deg);
  }

  .faq-body-collapsible {
      max-height: 1200px;
      overflow: hidden;
      transition: max-height 0.4s cubic-bezier(0, 1, 0, 1);
  }

  .faq-section--collapsed .faq-body-collapsible {
      max-height: 0;
  }

  .faq-question {
      margin: 0;
      padding: 0.2rem 0 0.5rem 0;
      font-size: 1.1rem;
      font-weight: 700;
      color: var(--text-header);
  }

  .faq-answer {
      margin: 0;
      padding: 0 0 0.2rem 0;
      font-size: 0.95rem;
      line-height: 1.6;
      color: var(--text-main);
  }

  .faq-answer a {
      color: var(--accent);
      text-decoration: none;
      border-bottom: 1px dashed var(--accent);
  }

  .faq-answer a:hover {
      border-bottom-style: solid;
  }
</style>

<script>
  // Search Logic
  document.addEventListener('DOMContentLoaded', () => {
      const filterableItems = document.querySelectorAll('.article-row, .sidebar-item, .featured-item-link');
      const gridContainer = document.querySelector('.page-layout-grid');

      let searchQuery = '';

      function applyFilters() {
          const controlsActive = searchQuery !== '';
          if (gridContainer) {
              if (controlsActive) {
                  gridContainer.classList.add('controls-active');
              } else {
                  gridContainer.classList.remove('controls-active');
              }
          }

          filterableItems.forEach(item => {
              const searchText = item.getAttribute('data-search-text') || '';
              const matchesSearch = searchText.includes(searchQuery);

              if (matchesSearch) {
                  item.classList.remove('hidden-by-search');
              } else {
                  item.classList.add('hidden-by-search');
              }
          });
      }

      const headerSearchInput = document.getElementById('header-search-input');

      function syncSearch(value) {
          if (headerSearchInput && headerSearchInput.value !== value) {
              headerSearchInput.value = value;
          }
          searchQuery = value.toLowerCase().trim();
          applyFilters();
      }

      if (headerSearchInput) {
          headerSearchInput.addEventListener('input', (e) => {
              syncSearch(e.target.value);
          });
      }

      // Check URL query parameters on load
      const params = new URLSearchParams(window.location.search);
      const searchParam = params.get('search');
      if (searchParam) {
          syncSearch(searchParam);
          // Clean the URL query param without reload
          const newUrl = window.location.protocol + "//" + window.location.host + window.location.pathname;
          window.history.replaceState({ path: newUrl }, '', newUrl);
      }
  });

  // Articles Expander
  const showMoreBtn = document.getElementById('show-more-btn');
  const articlesList = document.querySelector('.articles-list');
  if (showMoreBtn && articlesList) {
      showMoreBtn.addEventListener('click', () => {
          articlesList.classList.add('articles-list--expanded');
          showMoreBtn.style.display = 'none';
      });
  }

  // Sidebar News Expander
  const sidebarShowMoreBtn = document.getElementById('sidebar-show-more-btn');
  const sidebarList = document.querySelector('.sidebar-list');
  if (sidebarShowMoreBtn && sidebarList) {
      sidebarShowMoreBtn.addEventListener('click', () => {
          sidebarList.classList.add('sidebar-list--expanded');
          sidebarShowMoreBtn.closest('.sidebar-show-more-wrap').style.display = 'none';
      });
  }

  // Twitch/YouTube Live Swapper and Collapse Toggle
  const streamBlock = document.getElementById('stream-block');
  const statusDot = document.getElementById('stream-status-dot');
  const statusText = document.getElementById('stream-status-text');
  const embedContainer = document.getElementById('stream-embed-container');
  const toggleBtn = document.getElementById('toggle-stream-btn');
  const toggleText = toggleBtn?.querySelector('.toggle-text');
  const youtubeId = streamBlock?.getAttribute('data-youtube-id') || 'e-RHZvID8q8';

  if (streamBlock && embedContainer) {
      // 1. Fetch live status from Decapi.me
      fetch('https://decapi.me/twitch/uptime/ialexeyru')
          .then(res => res.text())
          .then(text => {
              const isLive = !text.toLowerCase().includes('offline');
              if (isLive) {
                  statusDot?.classList.add('live');
                  if (statusText) statusText.textContent = 'LIVE: Трансляция на Twitch';
                  streamBlock.classList.add('live-border');
                  embedContainer.innerHTML = `
                      <iframe
                          src="https://player.twitch.tv/?channel=ialexeyru&parent=ialexey.ru&parent=localhost&parent=127.0.0.1&autoplay=false"
                          style="border: 0; width: 100%; height: 100%;"
                          allowfullscreen="true">
                      </iframe>
                  `;
              } else {
                  statusDot?.classList.add('offline');
                  if (statusText) statusText.textContent = 'Видео';
                  streamBlock.classList.add('offline-border');
                  embedContainer.innerHTML = `
                      <iframe
                          src="https://www.youtube.com/embed/${youtubeId}"
                          style="border: 0; width: 100%; height: 100%;"
                          allowfullscreen="true"
                          allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                      </iframe>
                  `;
              }
          })
          .catch(() => {
              // Fallback to YouTube on error
              statusDot?.classList.add('offline');
              if (statusText) statusText.textContent = 'Видео';
              streamBlock.classList.add('offline-border');
              embedContainer.innerHTML = `
                  <iframe
                      src="https://www.youtube.com/embed/${youtubeId}"
                      style="border: 0; width: 100%; height: 100%;"
                      allowfullscreen="true"
                      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture">
                  </iframe>
              `;
          });

      // 2. Collapse Toggle
      if (toggleBtn && toggleText) {
          toggleBtn.addEventListener('click', () => {
              const isCollapsed = streamBlock.classList.toggle('stream-banner--collapsed');
              toggleText.textContent = isCollapsed ? 'Развернуть' : 'Свернуть';
          });
      }
  }

  // FAQ Collapse Toggle
  const faqSection = document.getElementById('faq');
  const toggleFaqBtn = document.getElementById('toggle-faq-btn');
  const faqToggleText = toggleFaqBtn?.querySelector('.faq-toggle-text');

  if (faqSection && toggleFaqBtn && faqToggleText) {
      const toggleFAQ = () => {
          const isCollapsed = faqSection.classList.toggle('faq-section--collapsed');
          faqToggleText.textContent = isCollapsed ? 'Развернуть' : 'Свернуть';
      };
      
      toggleFaqBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          toggleFAQ();
      });

      const faqHeaderRow = faqSection.querySelector('.faq-header-row');
      if (faqHeaderRow) {
          faqHeaderRow.style.cursor = 'pointer';
          faqHeaderRow.addEventListener('click', toggleFAQ);
      }
  }

  // Bulk Likes Loader for the main page
  const likesBadges = document.querySelectorAll('.post-likes-badge');
  if (likesBadges.length > 0) {
      const ids = Array.from(likesBadges)
          .map(badge => badge.getAttribute('data-post-id'))
          .filter(Boolean);
          
      if (ids.length > 0) {
          fetch(`/api/likes/batch?ids=${ids.join(',')}`)
              .then(res => res.json())
              .then(data => {
                  if (data) {
                      likesBadges.forEach(badge => {
                          const postId = badge.getAttribute('data-post-id');
                          const info = data[postId];
                          if (info) {
                              const valEl = badge.querySelector('.likes-count-val');
                              if (valEl) {
                                  valEl.textContent = String(info.likes);
                              }
                              (badge as HTMLElement).style.display = 'inline-flex';
                              if (info.user_liked) {
                                  badge.classList.add('liked');
                              }
                          }
                      });
                  }
              })
              .catch(err => console.error('Error fetching batch likes:', err));
      }
  }
</script>
