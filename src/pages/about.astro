---
import Layout from '../layouts/Layout.astro';

const title = "About Alex Getman | AI, automation and self-hosted systems";
const description = "Alex Getman is an Almaty-based AI mentor and technology consultant writing about AI, automation, developer tools and self-hosted systems.";
const schema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "name": "About Alex Getman",
  "url": "https://alexgetman.com/about/",
  "description": description,
  "inLanguage": "en-US",
  "mainEntity": {
    "@type": "Person",
    "name": "Alex Getman",
    "alternateName": "Алексей Гетманец",
    "url": "https://alexgetman.com/",
    "image": "https://alexgetman.com/avatar.png",
    "sameAs": [
      "https://t.me/alexgetmancom",
      "https://www.threads.net/@alexgetmanco",
      "https://github.com/alexgetmancom",
      "https://www.linkedin.com/in/alexgetmancom",
      "https://www.youtube.com/@alexgetmancom"
    ]
  }
});
---

<Layout
  title={title}
  description={description}
  schema={schema}
  canonicalUrl="https://alexgetman.com/about/"
  lang="en"
  siteName="Alex Getman"
  alternateLinks={[
    { hreflang: "en", href: "https://alexgetman.com/about/" },
    { hreflang: "ru", href: "https://alexgetman.com/ru/about/" },
    { hreflang: "x-default", href: "https://alexgetman.com/about/" }
  ]}
>
  <main class="content-page">
    <p class="eyebrow">About</p>
    <h1>Alex Getman</h1>
    <p class="lead">I am an AI mentor and technology consultant based in Almaty, Kazakhstan. I write about practical AI product changes, automation workflows, developer tools and self-hosted infrastructure.</p>

    <section>
      <h2>What I publish</h2>
      <p>The site collects short posts, longer notes, public project updates and feeds for people who want to follow AI and automation without losing the technical context.</p>
    </section>

    <section>
      <h2>Background</h2>
      <p>My work combines AI consulting, publishing automation, DevOps practice and self-hosted systems. I focus on tools that can be used in real workflows, not just announcements.</p>
    </section>

    <section>
      <h2>Projects and channels</h2>
      <p>Public code lives on GitHub, community discussions happen in Telegram and Discord, and English updates are available through the homepage, RSS and Threads.</p>
    </section>
  </main>
</Layout>

<style>
  .content-page {
    max-width: 780px;
    margin: 0 auto;
    padding: 2rem 0 4rem;
  }

  .eyebrow {
    margin: 0 0 0.75rem;
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.82rem;
    font-weight: 800;
  }

  h1 {
    margin: 0;
    font-size: clamp(2.4rem, 5vw, 4.4rem);
    line-height: 1.02;
    letter-spacing: 0;
  }

  .lead {
    margin: 1rem 0 2rem;
    color: var(--text-secondary);
    font-size: 1.15rem;
  }

  section {
    margin-top: 2rem;
  }

  h2 {
    margin: 0 0 0.6rem;
    font-size: 1.35rem;
    letter-spacing: 0;
  }

  p {
    color: var(--text-secondary);
  }
</style>
