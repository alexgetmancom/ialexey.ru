---
import { truncateText } from '../utils/helpers';

interface HomePost {
  id: number | string;
  url: string;
  title: string;
  excerpt: string;
  date: string;
  relativeDate: string;
  image: string | null;
  imageSrcSet?: string;
  views: number;
  categorySlug: string;
  category: string;
}

interface TopicStat {
  slug: string;
  label: string;
  count: number;
}

interface Project {
  name: string;
  kind: string;
  url: string;
}

interface Labels {
  archive: string;
  search: string;
  languageSwitch: string;
  empty: string;
  latestPosts: string;
  latestUpdates: string;
  trending: string;
  topics: string;
  projects: string;
  all: string;
  sidebarLabel: string;
  mskSuffix: string;
}

interface Props {
  posts: HomePost[];
  latestPosts: HomePost[];
  trendingPosts: HomePost[];
  topicStats: TopicStat[];
  projects: Project[];
  labels: Labels;
  locale: 'en' | 'ru';
  categoryBasePath: string;
}

const {
  posts,
  trendingPosts,
  labels,
  locale,
} = Astro.props;

const storyPosts = posts.slice(0, 3);
const updatePosts = posts.slice(3, 8);

function formatMskDate(value: string) {
  if (!value) return "";
  try {
    return new Intl.DateTimeFormat(locale === 'ru' ? 'ru-RU' : 'en-GB', {
      timeZone: "Europe/Moscow",
      day: "2-digit",
      month: "short",
      year: "numeric",
      hour: "2-digit",
      minute: "2-digit",
      hour12: false,
    }).format(new Date(value));
  } catch (e) {
    return value;
  }
}
---

<main class="home-page">
  {storyPosts.length ? (
    <section class="home-stage" aria-label={labels.latestPosts}>
      <div class="story-grid">
        {storyPosts.map((post, index) => (
          <a href={post.url} class={`story-card${post.image ? '' : ' story-card--no-image'}`}>
            <div class="story-card__media" aria-hidden="true">
              {post.image ? (
                <img
                  src={`/${post.image}`}
                  srcset={post.imageSrcSet}
                  alt=""
                  loading={index === 0 ? 'eager' : 'lazy'}
                  decoding="async"
                  sizes="(max-width: 820px) min(100vw, 430px), (max-width: 1180px) 42vw, 320px"
                />
              ) : (
                <span>{post.category}</span>
              )}
            </div>
            <div class="story-card__shade"></div>
            <div class="story-card__content">
              <div class="story-card__meta">
                <span class="pill">{post.category}</span>
                <time datetime={post.date}>{post.relativeDate || `${formatMskDate(post.date)} ${labels.mskSuffix}`}</time>
              </div>
              <h1>{post.title}</h1>
              {post.excerpt && <p>{truncateText(post.excerpt, 112)}</p>}
            </div>
          </a>
        ))}
      </div>

      <aside class="trending-panel" aria-label={labels.sidebarLabel}>
        <div class="section__header">
          <h2 class="section__title">{labels.trending}</h2>
          <a href={locale === 'ru' ? '/ru/search/' : '/search/'} class="section__link">{labels.search}</a>
        </div>
        <div class="compact-list">
          {trendingPosts.map((post) => (
            <a href={post.url} class="compact-row">
              <span>{post.category}</span>
              <strong>{truncateText(post.title, 82)}</strong>
            </a>
          ))}
        </div>
      </aside>
    </section>
  ) : (
    <p class="empty">{labels.empty}</p>
  )}

  {updatePosts.length > 0 && (
    <section class="updates-strip" aria-labelledby="updates-title">
      <div class="section__header">
        <h2 class="section__title" id="updates-title">{labels.latestUpdates}</h2>
        <a href={locale === 'ru' ? '/ru/archive/' : '/archive/'} class="section__link">{labels.archive}</a>
      </div>
      <div class="update-list">
        {updatePosts.map((post) => (
          <a href={post.url} class="update-row">
            <span>{post.category}</span>
            <strong>{truncateText(post.title, 74)}</strong>
            <time datetime={post.date}>{post.relativeDate || `${formatMskDate(post.date)} ${labels.mskSuffix}`}</time>
          </a>
        ))}
      </div>
    </section>
  )}
</main>

<style>
  .home-page {
    width: min(1528px, calc(100vw - 4rem));
    max-width: none;
    margin-left: 50%;
    transform: translateX(-50%);
    padding: 0.65rem 0 3rem;
    min-width: 0;
  }

  .home-stage {
    display: grid;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 380px);
    gap: 1rem;
    align-items: start;
  }

  .story-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }

  .story-card {
    position: relative;
    aspect-ratio: 9 / 16;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    color: var(--text-header);
    min-width: 0;
    overflow: hidden;
    isolation: isolate;
  }

  .story-card:hover {
    border-color: var(--border-hover);
  }

  .story-card__media,
  .story-card__shade {
    position: absolute;
    inset: 0;
  }

  .story-card__media {
    background:
      radial-gradient(circle at 35% 18%, rgba(240, 68, 101, 0.16), transparent 34%),
      linear-gradient(135deg, rgba(240, 68, 101, 0.1), rgba(255, 255, 255, 0.03));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    font-family: var(--font-mono);
    font-size: 0.86rem;
    font-weight: 800;
    text-align: center;
  }

  .story-card__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transform: scale(1.01);
  }

  .story-card__shade {
    z-index: 1;
    background:
      linear-gradient(180deg, rgba(8, 11, 16, 0.04) 0%, rgba(8, 11, 16, 0.1) 43%, rgba(8, 11, 16, 0.82) 78%, rgba(8, 11, 16, 0.96) 100%);
  }

  .story-card__content {
    position: absolute;
    z-index: 2;
    left: 0;
    right: 0;
    bottom: 0;
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    padding: clamp(1rem, 1.9vw, 1.35rem);
  }

  .story-card__meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.55rem;
  }

  .story-card__meta time {
    color: rgba(243, 246, 250, 0.74);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .story-card h1 {
    margin: 0;
    font-size: clamp(1.25rem, 2vw, 1.72rem);
    line-height: 1.04;
    letter-spacing: 0;
    overflow-wrap: anywhere;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .story-card p {
    margin: 0;
    color: rgba(243, 246, 250, 0.78);
    font-size: 0.86rem;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .pill {
    width: fit-content;
    padding: 0.2rem 0.5rem;
    border: 1px solid rgba(240, 68, 101, 0.36);
    border-radius: 6px;
    background: rgba(8, 11, 16, 0.55);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 800;
  }

  .trending-panel,
  .updates-strip {
    border: 1px solid var(--border);
    border-radius: 8px;
    background: var(--card-bg);
    min-width: 0;
  }

  .trending-panel {
    min-height: 100%;
    padding: 1.1rem;
  }

  .section__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.9rem;
  }

  .section__title {
    margin: 0;
    font-size: 1.2rem;
  }

  .section__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 34px;
    padding: 0.38rem 0.65rem;
    border: 1px solid var(--border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.02);
    color: var(--text-main);
    font-size: 0.86rem;
    font-weight: 800;
  }

  .section__link:hover {
    color: var(--text-header);
    border-color: var(--border-hover);
    background: var(--accent-glow);
  }

  .compact-list {
    display: grid;
  }

  .compact-row {
    display: grid;
    gap: 0.2rem;
    padding: 0.82rem 0;
    border-bottom: 1px solid var(--border);
    color: var(--text-main);
    min-width: 0;
  }

  .compact-row:last-child {
    border-bottom: 0;
  }

  .compact-row strong {
    color: var(--text-header);
    font-size: 0.92rem;
    line-height: 1.35;
    overflow-wrap: anywhere;
  }

  .compact-row span {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.74rem;
  }

  .updates-strip {
    margin-top: 1rem;
    padding: 1rem;
  }

  .update-list {
    display: grid;
    grid-template-columns: repeat(5, minmax(0, 1fr));
    gap: 0.8rem;
  }

  .update-row {
    display: grid;
    gap: 0.25rem;
    min-width: 0;
    padding: 0.2rem 0.25rem;
    color: var(--text-main);
  }

  .update-row span,
  .update-row time {
    color: var(--text-secondary);
    font-family: var(--font-mono);
    font-size: 0.72rem;
  }

  .update-row strong {
    color: var(--text-header);
    font-size: 0.9rem;
    line-height: 1.25;
    overflow-wrap: anywhere;
  }

  .empty {
    margin: 0;
    color: var(--text-secondary);
  }

  @media (max-width: 1180px) {
    .home-stage {
      grid-template-columns: 1fr;
    }

    .story-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }

    .trending-panel {
      min-height: 0;
    }
  }

  @media (max-width: 820px) {
    .story-grid {
      grid-template-columns: 1fr;
      justify-items: center;
    }

    .story-card {
      width: min(100%, 430px);
    }

    .update-list {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 520px) {
    .home-page {
      width: min(100%, calc(100vw - 1.5rem));
      padding-top: 0.25rem;
    }

    .story-card__content {
      padding: 1rem;
    }

    .story-card h1 {
      font-size: clamp(1.45rem, 7vw, 1.9rem);
    }

    .trending-panel,
    .updates-strip {
      padding: 0.9rem;
    }
  }
</style>
