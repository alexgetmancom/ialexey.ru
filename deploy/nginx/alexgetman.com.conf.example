server {
    listen 80;
    listen [::]:80;
    server_name alexgetman.com www.alexgetman.com;

    return 301 https://alexgetman.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name www.alexgetman.com;

    ssl_certificate /etc/letsencrypt/live/alexgetman.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/alexgetman.com/privkey.pem;

    return 301 https://alexgetman.com$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name alexgetman.com;

    root /home/deploy/ialexey-web;
    index index.html;

    ssl_certificate /etc/letsencrypt/live/alexgetman.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/alexgetman.com/privkey.pem;

    include /home/deploy/repos/ialexey-web/deploy/nginx/ialexey-cache.conf;

    location = /tg-feed/healthz {
        proxy_pass http://127.0.0.1:8788;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location = /tg-feed/webhook {
        proxy_pass http://127.0.0.1:8788;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    location / {
        try_files $uri $uri/ =404;
    }
}
